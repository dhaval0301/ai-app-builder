# ── AI Providers ─────────────────────────────────────────────────────────────
# Add at least one. The app falls back through providers in order:
#   OpenAI → Anthropic → Gemini → Ollama → built-in Template (no key needed)

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GEMINI_API_KEY=AIza...

# ── Ollama (local only) ───────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Provider selection ────────────────────────────────────────────────────────
# "auto"  → try each configured provider in order (recommended)
# "openai" | "anthropic" | "gemini" | "ollama" | "template"
AI_PROVIDER=auto

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of extra allowed origins (your Vercel URLs)
# Example: https://my-app.vercel.app,https://my-app-git-main-username.vercel.app
ALLOWED_ORIGINS=
